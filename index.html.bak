    function renderTools() {
        const container = document.getElementById("toolList");
        let html = "";
        CATEGORIES.forEach(cat => {
            const items = TOOLS.filter(t => t.c === cat);
            if(items.length === 0) return;
            html += `<div class="category"><h2>${cat}</h2><div class="tool-grid">`;
            items.forEach(t => {
                html += `<a href="${t.u}.html">${t.n}</a>`;
            });
            html += `</div></div>`;
        });
        container.innerHTML = html;
    }

    function filterTools() {
        const q = document.getElementById("searchInput").value.toLowerCase();
        const container = document.getElementById("toolList");
        if(!q) { renderTools(); return; }
        const matched = TOOLS.filter(t => t.n.includes(q) || t.c.includes(q));
        let html = `<div class="category"><h2>🔍 搜索结果 (${matched.length})</h2><div class="tool-grid">`;
        matched.forEach(t => { html += `<a href="${t.u}.html">${t.n}</a>`; });
        html += `</div></div>`;
        container.innerHTML = html;
    }

    renderTools();
